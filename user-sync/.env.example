# user-sync/.env.example
#
# Copy to .env and fill in real values for local development.
# Never commit .env to version control.

# Logging
RUST_LOG=info

# Auth
AUTH__TOKEN_URL=https://auth.example.com/oauth2/token
AUTH__CLIENT_ID=my-client-id
AUTH__CLIENT_SECRET=my-client-secret

# Source
SOURCE__USER_ENDPOINT=https://api.example.com/users
SOURCE__START_INTERVAL=30
SOURCE__END_INTERVAL=0
SOURCE__INTERVAL_LIMIT=7
SOURCE__WINDOW_SLEEP_SECS=60
SOURCE__INCLUDE_REALM_TYPES=

# Sink
SINK__DATABASE_URL=postgres://user:password@localhost:5432/mydb
SINK__SYNC_SQL=

# Scheduler
SCHEDULER__CRON=0 */30 * * * *
