# user-sync/.env.example — copy to .env and fill in values

# Scheduler
CRON="0 0 2 * * *"

# Source — DateWindowChunker
START_INTERVAL=30
END_INTERVAL=0
INTERVAL_LIMIT=7
INCLUDE_REALM_TYPES=

# Source — OAuth2Auth
TOKEN_URL=https://auth.example.com/oauth2/token
CLIENT_ID=my-client-id
CLIENT_SECRET=my-client-secret

# Source — HttpJsonFetcher
USER_ENDPOINT=https://user-service.example.com/api/users

# Sink — PostgresWriter
DATABASE_URL=postgres://user:password@localhost:5432/mydb

# Sink — RawSqlHook (optional)
SYNC_SQL=

# Logging
RUST_LOG=user_sync=info
